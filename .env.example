# =========================================================================
# Backend HGAC PoC - Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# Nunca subas el .env real al repositorio.
# =========================================================================

# --- App ---
APP_NAME=Backend HGAC PoC
APP_ENV=development
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Persistencia / Evidencia (legacy, opcional) ---
DATABASE_URL=sqlite:///./data/hgac_poc.db
EVIDENCE_BASE_PATH=./evidence/snapshots
EVIDENCE_PUBLIC_BASE_URL=http://localhost:8000/evidence

# --- LPR ---
# Opciones: local | plate_recognizer
LPR_PROVIDER=local
LPR_MIN_CONFIDENCE=0.50

# --- LPR local gratuito ---
LOCAL_LPR_OCR_ENGINE=easyocr
LOCAL_LPR_GPU=false
LOCAL_LPR_REGION=do

# Primero déjalo en false para validar cámara completa con /lpr/debug/snapshot.
# Luego, cuando tengamos una imagen real, activamos ROI fijo y ajustamos coordenadas.
LOCAL_LPR_USE_FIXED_ROI=false
LOCAL_LPR_ROI_X=0
LOCAL_LPR_ROI_Y=0
LOCAL_LPR_ROI_WIDTH=0
LOCAL_LPR_ROI_HEIGHT=0
LOCAL_LPR_MIN_TEXT_LENGTH=5
LOCAL_LPR_MAX_TEXT_LENGTH=8

# --- Plate Recognizer (opcional/fallback; no usar en PoC gratuita) ---
PLATE_RECOGNIZER_API_TOKEN=
PLATE_RECOGNIZER_API_URL=https://api.platerecognizer.com/v1/plate-reader/
PLATE_RECOGNIZER_REGIONS=do
PLATE_RECOGNIZER_TIMEOUT_SECONDS=10

# --- LPR módulo (POST /api/v1/lpr/reads) ---
# LPR_READ_MIN_CONFIDENCE está en escala 0-100 (la respuesta usa %), separado
# del legacy LPR_MIN_CONFIDENCE (0-1) que usa /lpr/read.
LPR_ENABLED=true
# Motor LPR de PLACA. Alias aceptados (se resuelven en la factory):
#   opencv_easyocr_poc | opencv_easyocr  -> motor propio OpenCV+EasyOCR (default)
#   simplelpr_rd_poc   | simplelpr       -> SimpleLPR (opcional; ver bloque abajo)
#   auto                                 -> intenta SimpleLPR y cae a OpenCV
LPR_ENGINE=opencv_easyocr_poc
# Motor de respaldo cuando el primario es SimpleLPR/auto y no detecta o falla.
# Vacío = sin fallback (SimpleLPR ausente daría 503 controlado). Default: OpenCV.
LPR_FALLBACK_ENGINE=opencv_easyocr
# Escala 0-100. Con la ráfaga multiframe se baja respecto al single-frame: el
# consenso (varios votos) compensa una confianza individual menor.
LPR_READ_MIN_CONFIDENCE=55
LPR_SAVE_DEBUG_FRAMES=true
LPR_MAX_PROCESSING_MS=5000
LPR_EVIDENCE_BASE_PATH=./evidence/lpr

# --- LPR: ráfaga multiframe + consenso (placas en movimiento) ---
# Se captura una ráfaga por lectura (~1-2 s del paso del vehículo), se puntúa la
# calidad del ROI de cada frame (nitidez/brillo), se procesan los mejores N y se
# vota por consenso. count=1 => comportamiento single-frame (compatibilidad).
# 12 frames x 120 ms ~= 1.4 s de ventana.
LPR_BURST_FRAME_COUNT=12
LPR_BURST_INTERVAL_MS=120
LPR_BURST_TOP_FRAMES=5
# Calidad del ROI de placa: nitidez (varianza de Laplaciano) y brillo (0-255).
LPR_MIN_FRAME_SHARPNESS=80
LPR_MIN_FRAME_BRIGHTNESS=30
LPR_MAX_FRAME_BRIGHTNESS=235
# Consenso: votos mínimos (frames distintos con la misma placa) para aceptar con
# LPR_READ_MIN_CONFIDENCE; o confianza alta suficiente para aceptar de un frame.
LPR_CONSENSUS_MIN_VOTES=2
LPR_SINGLE_FRAME_ACCEPT_CONFIDENCE=75
# Guardar los top frames de la ráfaga como evidencia (burst_frame_urls). Off por
# defecto para no llenar evidence/ con archivos.
LPR_SAVE_BURST_FRAMES=false

# Evidencia de depuración para CALIBRAR el ROI desde Ignition: guarda el recorte
# del ROI de placa, del ROI de rótulo y un overlay del frame con los recuadros.
# Solo escribe si la cámara tiene algún ROI; nunca rompe la respuesta.
LPR_SAVE_DEBUG_EVIDENCE=true
LPR_EVIDENCE_JPEG_QUALITY=90

# --- LPR: lectura de RÓTULO de camión (identificador corto, p.ej. E204) ---
# Independiente de la placa: usa rotulo_roi de la cámara, validador propio
# (LETTER_3_DIGITS) y el motor OpenCV/EasyOCR. Sin rotulo_roi no se intenta.
LPR_ROTULO_ENABLED=true
# CSV de formatos del catálogo de rótulo (vacío = LETTER_3_DIGITS + LETTERS_2_4_DIGITS).
LPR_ROTULO_FORMAT_NAME=
LPR_ROTULO_READ_MIN_CONFIDENCE=60
LPR_ROTULO_MIN_TEXT_LENGTH=3
LPR_ROTULO_MAX_TEXT_LENGTH=6
LPR_ROTULO_MIN_SERIAL_DIGITS=2
# Modo de rendimiento del motor: fast | balanced | exhaustive (debug, lento).
LPR_MODE=balanced
# Mínimo de dígitos para que un candidato sea placa (descarta "DOMIN", "REP"...).
LPR_MIN_SERIAL_DIGITS=3
# Padding del recorte de placa (asimétrico: más a la izquierda para no cortar la letra inicial).
LPR_PAD_LEFT_RATIO=0.35
LPR_PAD_RIGHT_RATIO=0.15
LPR_PAD_Y_RATIO=0.12
# Formato(s) esperado(s): CSV de nombres del catálogo. Catálogo:
#   LETTER_6_DIGITS       -> ^[A-Z][0-9]{6}$    (p.ej. L460432)
#   TWO_LETTERS_5_DIGITS  -> ^[A-Z]{2}[0-9]{5}$ (p.ej. OF00105)
# Por defecto se aceptan ambos; para exigir uno solo, deja solo ese nombre, p.ej.:
#   LPR_PLATE_FORMAT_NAME=TWO_LETTERS_5_DIGITS
LPR_PLATE_FORMAT_NAME=LETTER_6_DIGITS,TWO_LETTERS_5_DIGITS
# Override de regex SOLO para un nombre fuera del catálogo (vacío = usar catálogo).
LPR_PLATE_FORMAT_REGEX=
LPR_PLATE_EXPECTED_LENGTH=7

# --- LPR: catálogo de placas dominicanas (referencia operativa DGII) ---
# Catálogo OPERATIVO para la PoC (no fuente legal definitiva). No autocorrige
# placas ni reemplaza validación futura contra RNTT/Navis/base autorizada.
LPR_ENABLE_DOMINICAN_PLATE_CATALOG=true
# Distancia de caracteres para considerar dos candidatos "casi iguales" (1 = un carácter).
LPR_AMBIGUOUS_CANDIDATE_DISTANCE=1
# Si la diferencia de score entre dos candidatos válidos es menor a esto -> ambiguo.
LPR_AMBIGUOUS_MIN_SCORE_DELTA=15
# Preparado para exigir confirmación multi-frame (aún no implementado).
LPR_REQUIRE_MULTIFRAME_CONFIRMATION=false

# --- LPR: motor alternativo SimpleLPR (si LPR_ENGINE=simplelpr/auto) ---
# SimpleLPR es dependencia OPCIONAL y comercial (trial 60 días). Solo se importa
# si el motor activo lo requiere. NO pongas aquí URLs RTSP ni credenciales.
# Estas variables aceptan también los alias del spec (no rompen el monitor continuo):
#   SIMPLE_LPR_ENABLED            == SIMPLELPR_ENABLED
#   SIMPLE_LPR_COUNTRIES          == SIMPLELPR_COUNTRY_CODES
#   SIMPLE_LPR_PRODUCT_KEY_PATH   == SIMPLELPR_LICENSE_PATH
# La confianza del engine es SIMPLE_LPR_MIN_CONFIDENCE (0-100); NO uses
# SIMPLELPR_MIN_CONFIDENCE para el engine: ese nombre ya lo usa el monitor
# continuo de abajo en escala 0-1.
SIMPLE_LPR_ENABLED=true
# RD no tiene plantilla propia: se activan países latinos vecinos SOLO para OCR
# alfanumérico (19=Colombia, 74=Puerto Rico, 96=Venezuela). La AUTORIDAD de
# formato sigue siendo el catálogo dominicano del backend, no estos países.
SIMPLE_LPR_COUNTRIES=19,74,96
# Ruta opcional a la licencia .xml (vacío = modo evaluación de 60 días).
SIMPLE_LPR_PRODUCT_KEY_PATH=
# Confianza mínima del match OCR (escala 0-100) para considerarlo.
SIMPLE_LPR_MIN_CONFIDENCE=55
# CPU por defecto. use_gpu=false + cuda_device_id=-1 => CPU. max_concurrent_ops=0 => auto.
SIMPLE_LPR_USE_GPU=false
SIMPLE_LPR_CUDA_DEVICE_ID=-1
SIMPLE_LPR_MAX_CONCURRENT_OPS=0
# Detección/recorte de región de placa por SimpleLPR (si el binding lo soporta).
SIMPLE_LPR_PLATE_REGION_DETECTION=true
SIMPLE_LPR_CROP_TO_PLATE_REGION=false
# Corrección OCR posicional RD: máx. sustituciones letra<->dígito antes de penalizar
# fuerte la confianza, y penalización por sustitución (escala 0-100).
SIMPLE_LPR_MAX_OCR_SUBSTITUTIONS=2
SIMPLE_LPR_SUBSTITUTION_PENALTY=12
# Tracker multi-frame de SimpleLPR. NO usado en v1 (un frame por request; el
# consenso vive en LprService). Reservado para una mejora posterior.
SIMPLE_LPR_TRIGGER_WINDOW_SECONDS=3.0
SIMPLE_LPR_MAX_IDLE_SECONDS=2.0
SIMPLE_LPR_MIN_TRIGGER_FRAME_COUNT=3
SIMPLE_LPR_THUMBNAIL_WIDTH=256
SIMPLE_LPR_THUMBNAIL_HEIGHT=128
SIMPLE_LPR_COUNTRY_FALLBACK_MODE=latin_neighbors


# --- SimpleLPR continuo (SDK comercial/evaluacion) ---
SIMPLELPR_RTSP_URL=
SIMPLELPR_CAMERA_ID=
SIMPLELPR_CAMERA_NAME=
SIMPLELPR_COUNTRIES=19,74,96
SIMPLELPR_PRODUCT_KEY=
SIMPLELPR_MIN_CONFIDENCE=0.80
SIMPLELPR_CORRECTION_PENALTY=0.08
SIMPLELPR_MAX_WIDTH=1920
SIMPLELPR_MAX_HEIGHT=1080
SIMPLELPR_MAX_IN_FLIGHT=6
SIMPLELPR_FRAME_STRIDE=1
SIMPLELPR_TRACKER_WINDOW=1.5
SIMPLELPR_TRACKER_IDLE=0.75
SIMPLELPR_TRACKER_MIN_FRAMES=2
SIMPLELPR_DEDUP_SECONDS=30






# --- Cámara ---
# Opciones: webcam | rtsp
CAMERA_PROVIDER=webcam
WEBCAM_INDEX=0
RTSP_URL=
CAMERA_CAPTURE_TIMEOUT_SECONDS=5
# Registro de cámaras (JSON). Copia config/cameras.example.json a
# config/cameras.json (NO se versiona) y referencia las URLs RTSP por nombre de
# variable (source_env), nunca dentro del JSON. Si el archivo no existe, el
# backend usa la webcam USB por defecto CAM-P-01.
CAMERA_REGISTRY_PATH=./config/cameras.json
# URLs RTSP reales referenciadas por config/cameras.json (source_env). Mantenlas
# SOLO aquí en tu .env local; nunca en el repositorio.
# Formato: rtsp://USUARIO:CLAVE@IP:554/stream1  (NO subas la URL real al repo).
CAMERA_HIT_LPR_01_RTSP_URL=
CAMERA_P1_CARRIL_1_RTSP_URL=
CAMERA_P1_CARRIL_2_RTSP_URL=

# --- Cámara: live stream MJPEG (preview en Ignition) ---
# FPS objetivo del stream /stream.mjpg (empezar en 10; no forzar 30 todavía).
CAMERA_STREAM_FPS=10
CAMERA_STREAM_JPEG_QUALITY=75
CAMERA_STREAM_WIDTH=640
CAMERA_STREAM_HEIGHT=480
# Margen para el primer frame (apertura + warm-up de webcam en Windows/DSHOW).
CAMERA_STREAM_OPEN_TIMEOUT_SECONDS=15

# --- BioStar 2 ---
BIOSTAR_HOST=
BIOSTAR_PORT=443
BIOSTAR_USERNAME=
BIOSTAR_PASSWORD=
# SSL verify EXPLÍCITO: false para certificados autofirmados en LAN portuaria.
BIOSTAR_VERIFY_SSL=false
BIOSTAR_TIMEOUT_SECONDS=10
BIOSTAR_DISPLAY_TIMEZONE=America/Santo_Domingo
BIOSTAR_USERS_CACHE_TTL_SECONDS=60
BIOSTAR_EVENTS_HOURS_BACK=24

# --- BioStar 2 local / monitor de lector ---
# Perfil del lector facial/tarjeta/huella conectado a ESTA PC. Lo usan tanto el
# monitor (scripts/monitor_biostar_local.py) como el endpoint
# GET /biostar/events/latest (este último solo lee BIOSTAR_LOCAL_OUTPUT_PATH).
BIOSTAR_LOCAL_HOST=127.0.0.1
BIOSTAR_LOCAL_PORT=443
BIOSTAR_LOCAL_SCHEME=https
BIOSTAR_LOCAL_USER=
BIOSTAR_LOCAL_PASSWORD=
# Archivo JSON donde el monitor publica el último evento y que expone el backend.
BIOSTAR_LOCAL_OUTPUT_PATH=C:/Users/Public/hgac_biostar_local.json

# --- RNTT (portal/stub legacy; alimenta /crossing/evaluate) ---
RNTT_PORTAL_URL=
RNTT_HEADLESS=true
# Si se habilita, RnttService devuelve respuestas simuladas (útil para PoC sin Selenium)
RNTT_USE_STUB=true

# --- RNTT API ASMX (consulta real chofer/camión) ---
# El WebService RNTT EXIGE autenticación (sin credenciales responde
# "No tiene acceso a este servicio"). BASE_URL, USERNAME y PASSWORD son
# OBLIGATORIOS; si falta alguno, los endpoints RNTT responden 503.
# NO coloques credenciales reales aquí: son placeholders.
RNTT_BASE_URL=http://200.88.113.120:2056/WebService1.asmx
RNTT_USERNAME=
RNTT_PASSWORD=
# Opcional (default 30). Timeout por consulta al WebService.
RNTT_TIMEOUT_SECONDS=20
# Modo de autenticación confirmado en producción: header (Username/Password) | hmac (Username/Time/Token)
RNTT_AUTH_MODE=header
# DEBUG: habilita intentos de diagnóstico del script original (incluye no-auth). Dejar en false.
RNTT_ENABLE_DIAGNOSTIC_FALLBACKS=false

# --- Navis (API interna HIT, OAuth password grant) ---
NAVIS_API_BASE=
# Si el token vive en otro host, fija la URL exacta aquí (tiene prioridad sobre API_BASE+TOKEN_PATH).
NAVIS_TOKEN_URL=
NAVIS_TOKEN_PATH=oauth/token
NAVIS_GRANT_TYPE=password
NAVIS_CLIENT_ID=
NAVIS_CLIENT_SECRET=
NAVIS_USERNAME=
NAVIS_PASSWORD=
NAVIS_SCOPE=
NAVIS_TIMEOUT_SECONDS=25

# --- Wialon (GPS Gurtam; nube o local de HIT) ---
WIALON_TOKEN=
# Nube: https://hst-api.wialon.com | Local HIT: http://<ip-servidor>:8080
WIALON_HOST=https://hst-api.wialon.com
WIALON_TIMEOUT_SECONDS=15
WIALON_ONLINE_SECONDS=300
WIALON_TERMINAL_GEOFENCE_NAMES=TERMINAL GENERAL,TERMINAL
WIALON_GATE_ZONE_KEYWORDS=GATE,ENTRADA,SALIDA,GARITA,CARRIL,ACCESO,RUTA ENTRADA

# --- Ignition (puente JSON temporal y futuro consumo REST) ---
IGNITION_JSON_OUTPUT_DIR=./data/ignition_outbox
# Archivo fijo del último LPR consumido por el gateway de Ignition.
IGNITION_LPR_LATEST_PATH=C:/Users/Public/hgac_lpr.json
IGNITION_LPR_EVENT_DIR=C:/Users/Public/hgac_lpr_events
IGNITION_BASE_URL=http://localhost:8088
IGNITION_EVENT_ENDPOINT=/system/webdev/hgac/events/vehicle-observation
IGNITION_API_TOKEN=change-me
IGNITION_TIMEOUT_SECONDS=5


# --- Supervisor local del PoC ---
HGAC_START_BACKEND=true
HGAC_START_BIOSTAR=true
HGAC_START_LPR=true
HGAC_RESTART_DELAY_SECONDS=15
BIOSTAR_LOCAL_DEVICE=
BIOSTAR_LOCAL_POLL_SECONDS=1
# Python donde esta instalado SimpleLPR (puede ser distinto al .venv del backend).
SIMPLELPR_PYTHON=C:/Users/USUARIO/AppData/Local/Programs/Python/Python312/python.exe

